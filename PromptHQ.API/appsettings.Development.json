{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TelegramSettings": {
    "BotToken": "YOUR_TELEGRAM_BOT_TOKEN",
    "SecretToken": "YOUR_WEBHOOK_SECRET_TOKEN",
    "WebhookUrl": "https://your-domain.com/api/telegram/webhook"
  },
  "DiscordSettings": {
    "PublicKey": "YOUR_DISCORD_PUBLIC_KEY",
    "InteractionsEndpointUrl": "https://your-domain.com/api/discord/interactions"
  },
  "AIProvidersConfig": {
    "DefaultProvider": "GroqLlama70B",
    "Providers": {
