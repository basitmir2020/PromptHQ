        "ModelName": "llama-3.3-70b-versatile"
      },
      "OpenAIGPT4o": {
        "DisplayName": "GPT-4o (OpenAI)",
        "ApiKey": "YOUR_OPENAI_API_KEY",
        "BaseUrl": "https://api.openai.com/v1/",
        "ModelName": "gpt-4o"
      },
      "OpenRouterClaude": {
        "DisplayName": "Claude Sonnet 4.6 (OpenRouter)",
        "ApiKey": "YOUR_OPENROUTER_API_KEY",
